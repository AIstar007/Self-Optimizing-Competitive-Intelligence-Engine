# Production Environment Configuration
# Use this for production - DO NOT COMMIT SECRETS

# Application
ENV=production
DEBUG=false
LOG_LEVEL=warn
LOG_FORMAT=json

# Server
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4
RELOAD=false

# Database
DATABASE_URL=postgresql://ci_user:${DB_PASSWORD}@postgres-prod.example.com:5432/competitive_intelligence
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false
DATABASE_SSL=require

# Cache
REDIS_URL=redis://redis-prod.example.com:6379
CACHE_TTL=3600

# LLM Providers
OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_MODEL=gpt-4
OPENAI_ORGANIZATION=${OPENAI_ORGANIZATION}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
ANTHROPIC_MODEL=claude-3-opus-20240229
OLLAMA_BASE_URL=http://ollama-prod.example.com:11434

# Security
JWT_SECRET=${JWT_SECRET}
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400
HTTPS_ONLY=true
SECURE_COOKIES=true

# CORS
CORS_ORIGINS=["https://competitive-intelligence.com", "https://www.competitive-intelligence.com"]
CORS_ALLOW_CREDENTIALS=true

# Features
ENABLE_SWAGGER=false
ENABLE_METRICS=true
ENABLE_PROFILING=false

# Testing
TESTING=false

# Logging
LOG_FILE=/var/log/ci-engine/app.log
LOG_MAX_SIZE=104857600
LOG_BACKUP_COUNT=30

# Monitoring
SENTRY_DSN=${SENTRY_DSN}
DATADOG_ENABLED=true
DATADOG_API_KEY=${DATADOG_API_KEY}
PROMETHEUS_ENABLED=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# Backup & Disaster Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
