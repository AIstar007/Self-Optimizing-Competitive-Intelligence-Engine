# Staging Environment Configuration
# Use this for staging/pre-production

# Application
ENV=staging
DEBUG=false
LOG_LEVEL=info
LOG_FORMAT=json

# Server
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=2
RELOAD=false

# Database
DATABASE_URL=postgresql://ci_user:${DB_PASSWORD}@postgres-staging.example.com:5432/competitive_intelligence
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# Cache
REDIS_URL=redis://redis-staging.example.com:6379
CACHE_TTL=3600

# LLM Providers
OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_MODEL=gpt-4
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
ANTHROPIC_MODEL=claude-3-opus-20240229
OLLAMA_BASE_URL=http://ollama-staging.example.com:11434

# Security
JWT_SECRET=${JWT_SECRET}
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# CORS
CORS_ORIGINS=["https://staging.competitive-intelligence.com"]
CORS_ALLOW_CREDENTIALS=true

# Features
ENABLE_SWAGGER=false
ENABLE_METRICS=true
ENABLE_PROFILING=false

# Testing
TESTING=false

# Logging
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=10

# Monitoring
SENTRY_DSN=${SENTRY_DSN}
DATADOG_ENABLED=true
